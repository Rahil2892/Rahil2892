#include <iostream>
using namespace std;
class circle
{private:
float r,a,c;
public:
circle()
{ 
  r=0;
}
void access()
{

    std::cout<<"\n enter radius  "<<endl;
    cin>>r;

}
void area();
void circumference();
void print();

};
void circle::area()
{
    a=3.14*r*r;

}
void circle::circumference()
{
    c=2*3.14*r;

}
void circle::print()
{

    std::cout<<"the radius is  "<<r<<endl;
    std::cout<<"the area is  "<<a<<endl;
    std::cout<<"the circumference is  "<<c<<endl;
}
 
